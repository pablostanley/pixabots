{
  "name": "@pixabots/react",
  "version": "0.2.0",
  "description": "React component for Pixabots — drop <Pixabot id=\"xxxx\" /> anywhere",
  "license": "MIT",
  "author": "Pablo Stanley (https://pablostanley.substack.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/pablostanley/pixabots",
    "directory": "packages/react"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@pixabots/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
