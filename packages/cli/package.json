{
  "name": "pixabots",
  "version": "0.1.0",
  "description": "CLI — print and download Pixabots from your terminal",
  "license": "MIT",
  "author": "Pablo Stanley (https://pablostanley.substack.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/pablostanley/pixabots",
    "directory": "packages/cli"
  },
  "type": "module",
